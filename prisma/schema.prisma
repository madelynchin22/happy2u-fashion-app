generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          String    @default("viewer") // admin | buyer | operation | finance | warehouse
  outletId      String?
  outlet        Outlet?   @relation(fields: [outletId], references: [id])
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  createdSamples     SampleOrder[]    @relation("CreatedBy")
  createdPOs         PurchaseOrder[]  @relation("POCreatedBy")
  createdShipments   Shipment[]
  createdDeliveries  Delivery[]
}

// ─── OUTLETS ─────────────────────────────────────────────────────────────────

model Outlet {
  id          String  @id @default(cuid())
  name        String
  marking     String  @unique   // e.g. JN75-H2UHQ, TH-BFZPV-A
  country     String  @default("MY")  // MY | TH
  address     String?
  isHQ        Boolean @default(false)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())

  users             User[]
  packingListItems  PackingListItem[]
  shipments         Shipment[]
  deliveries        Delivery[]
  outletDeliveries  OutletDelivery[]
  locationInventories LocationInventory[]
}

// ─── EXCHANGE RATE ───────────────────────────────────────────────────────────

model ExchangeRate {
  id        String   @id @default(cuid())
  fromCcy   String   // RMB
  toCcy     String   // RM
  rate      Float    // e.g. 0.62
  setBy     String?
  setAt     DateTime @default(now())
}

// ─── MANUFACTURERS ───────────────────────────────────────────────────────────

model Manufacturer {
  id            String  @id @default(cuid())
  name          String
  nameEn        String?
  contactName   String?
  contactPhone  String?
  contactWechat String?
  contactEmail  String?
  country       String  @default("CN")
  moq           Int?
  leadTimeDays  Int?
  rating        Float?  // supplier rating 1-5
  paymentTerms  String?
  materials     String?   // comma-separated: "PU,genuine leather,suede"
  notes         String?
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sampleOrders    SampleOrder[]
  purchaseOrders  PurchaseOrder[]
  productLibrary  ProductLibrary[]
}

// ─── PRODUCT MATERIALS LIBRARY ───────────────────────────────────────────────

model Material {
  id            String  @id @default(cuid())
  name          String
  materialType  String  // upper | lining | midsole | outsole | hardware | insole | heel | platform | sole
  colorCode     String?
  colorName     String?
  supplier      String?
  photoUrl      String?
  swatchUrl     String?
  notes         String?
  createdAt     DateTime @default(now())
}

// ─── COLLECTIONS ─────────────────────────────────────────────────────────────

model Collection {
  id          String  @id @default(cuid())
  name        String
  season      String
  status      String  @default("draft") // draft | active | closed
  createdAt   DateTime @default(now())

  sampleOrders   SampleOrder[]
  purchaseOrders PurchaseOrder[]
}

// ─── SAMPLE ORDERS ───────────────────────────────────────────────────────────

model SampleOrder {
  id              String  @id @default(cuid())
  orderNumber     String  @unique  // SO-2026-001
  version         Int     @default(1)
  parentId        String?
  parent          SampleOrder?  @relation("SampleVersions", fields: [parentId], references: [id])
  children        SampleOrder[] @relation("SampleVersions")

  // Header
  productName     String
  productNumber   String?
  brand           String  @default("Happy2U")
  season          String?
  sampleSize      String? // EU 38
  lastModel       String?
  dateSent        DateTime?
  deadline        DateTime?

  // Relations
  manufacturerId  String
  manufacturer    Manufacturer @relation(fields: [manufacturerId], references: [id])
  collectionId    String?
  collection      Collection?  @relation(fields: [collectionId], references: [id])

  // Status
  status          String  @default("draft") // draft | sent | received | approved | rejected
  sentAt          DateTime?
  receivedAt      DateTime?

  // Shipping tracking
  trackingNumber  String?
  courierCompany  String?
  shipOutDate     DateTime?

  // Product spec fields matching your PO format
  supplierSku     String?
  h2uSku          String?
  mainSku         String?  // style-level SKU e.g. S1800
  colorName       String?
  colorCode       String?  // single letter/code for SKU e.g. H
  materialUpper   String?
  materialLining  String?
  materialMidsole String?
  materialOutsole String?
  hardware        String?
  logoSpec        String?
  heelSpec        String?
  platformSpec    String?

  // Material remarks & photos per spec row
  materialUpperRemark    String?
  materialUpperPhoto     String?
  materialLiningRemark   String?
  materialLiningPhoto    String?
  materialMidsoleRemark  String?
  materialMidsolePhoto   String?
  materialOutsoleRemark  String?
  materialOutsolePhoto   String?
  hardwareRemark         String?
  hardwarePhoto          String?
  logoSpecRemark         String?
  logoSpecPhoto          String?
  heelSpecRemark         String?
  heelSpecPhoto          String?
  platformSpecRemark     String?
  platformSpecPhoto      String?

  // Multi-view photos (stored as JSON array of URLs)
  photoSideUrl    String?
  photoBackUrl    String?
  photoFrontUrl   String?
  photoPlatformUrl String?
  photoHeelUrl    String?
  photoExtraUrls  String?  // JSON array

  // Notes per view
  notesA          String?  // Side view notes
  notesB          String?  // Back view notes
  notesC          String?  // Front view notes
  notesD          String?  // Platform notes
  notesE          String?  // Heel notes
  generalNotes    String?

  // IP protection
  designSource    String?  // "in-house" | "reference" | "licensed"
  ipNotes         String?  // document design origin

  // Amendment notes (for v2+)
  amendmentNotes  String?

  // Received stage fields
  receivedRemark  String?
  productCostRmb  Float?
  productCostRm   Float?

  // Cost & pricing (kept for PO stage)
  costRmb         Float?
  costRm          Float?
  suggestedRetailLow  Float?
  suggestedRetailHigh Float?

  // Product evaluation fields
  category        String?  // e.g., Loafers, Sneakers, Sandals
  moq             Int?     // minimum order quantity
  bulkCostEst     Float?   // estimated bulk cost in RM
  leadTime        Int?     // lead time in days
  sizesOffered    String?  // e.g., "EU 35-41"
  colorVariants   String?  // JSON: [{name,hex}]
  trendInspiration String? // inspiration/trend description
  predecessorSku  String?  // previous SKU this is based on
  predecessorLesson String? // lessons learned from predecessor
  launchType      String?  // "market_test" | "full_launch"

  createdById     String?
  createdBy       User?    @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  poItems         PurchaseOrderItem[]
  productLibraries ProductLibrary[]
}

// ─── PURCHASE ORDERS ─────────────────────────────────────────────────────────

model PurchaseOrder {
  id              String  @id @default(cuid())
  poNumber        String  @unique  // PO-2026-001
  date            DateTime @default(now())

  manufacturerId  String
  manufacturer    Manufacturer @relation(fields: [manufacturerId], references: [id])
  collectionId    String?
  collection      Collection?  @relation(fields: [collectionId], references: [id])

  brand           String  @default("Happy2U")
  productName     String?   // main product display name
  deliveryDate    DateTime?
  currency        String  @default("RMB")

  // Order classification
  poType          String?   // "test" | "reorder" | "replen" | "clear"
  sampleOrderId   String?   // linked sample order (PO level)
  parentPoNumber  String?   // reference to parent PO for reorder/replen

  // Logistics
  destination     String?   // "Melaka HQ" | "Split: HQ + 3 outlets" etc.
  paymentTerms    String?   // "30% deposit / 70% pre-ship"
  paymentIncoterm String?   // "FOB Guangzhou"
  fxRate          Float?    // locked exchange rate ¥/RM

  // Production timeline dates
  productionStartDate DateTime?
  qcDate              DateTime?
  shipDate            DateTime?
  paymentPaidDate     DateTime?

  // Insights & allocations
  sizeCurveInsight String?
  allocations      String?  // JSON: [{destination,pairs,pct}]

  // Totals (calculated)
  totalPairs      Int     @default(0)
  totalPrice      Float   @default(0)

  status          String  @default("draft") // draft | sent | in_production | shipped | closed
  notes           String?
  pdfUrl          String?

  createdById     String?
  createdBy       User?   @relation("POCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           PurchaseOrderItem[]
  packingLists    PackingList[]
  shipmentItems   ShipmentItem[]
  outletDeliveries OutletDelivery[]
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  poId            String
  po              PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  sampleOrderId   String?
  sampleOrder     SampleOrder? @relation(fields: [sampleOrderId], references: [id])

  supplierSku     String?
  h2uSku          String?
  colorName       String?
  colorCode       String?
  brand           String?
  materialUpper   String?
  materialLining  String?
  materialMidsole String?
  materialOutsole String?
  hardware        String?
  logoSpec        String?
  remark          String?
  photoUrl        String?
  deliveryDate    DateTime?

  // Size run EU 35-42
  qty35           Int     @default(0)
  qty36           Int     @default(0)
  qty37           Int     @default(0)
  qty38           Int     @default(0)
  qty39           Int     @default(0)
  qty40           Int     @default(0)
  qty41           Int     @default(0)
  qty42           Int     @default(0)
  totalPairs      Int     @default(0)

  discountPrice   Float?
  lineTotal       Float?

  outletAllocations String?  // JSON: [{outletId, qty36-42}] per-outlet size breakdown

  // Actual ship-out date from manufacturer (per item, independent of PO-level shipDate)
  itemShipDate    DateTime?

  // Goods receipt
  receivedQty     Int?
  defectQty       Int?
  receiptNotes    String?
  receiptDate     DateTime?

  packingListItems PackingListItem[]
  deliveryItems    DeliveryItem[]
}

// ─── PACKING LIST ─────────────────────────────────────────────────────────────

model PackingList {
  id          String  @id @default(cuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id])
  totalPairs  Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       PackingListItem[]
}

model PackingListItem {
  id              String  @id @default(cuid())
  packingListId   String
  packingList     PackingList @relation(fields: [packingListId], references: [id], onDelete: Cascade)

  poItemId        String
  poItem          PurchaseOrderItem @relation(fields: [poItemId], references: [id])

  outletId        String
  outlet          Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)

  // Size breakdown for this outlet
  qty36           Int     @default(0)
  qty37           Int     @default(0)
  qty38           Int     @default(0)
  qty39           Int     @default(0)
  qty40           Int     @default(0)
  qty41           Int     @default(0)
  qty42           Int     @default(0)
  totalPairs      Int     @default(0)

  deliveryDate    DateTime?
  remark          String?
}

// ─── SHIPMENTS ────────────────────────────────────────────────────────────────

model Shipment {
  id              String  @id @default(cuid())
  shipmentNumber  String  @unique  // SH-2026-001
  containerNumber String?
  vesselName      String?
  blNumber        String?
  portOrigin      String?
  portDestination String?
  shipDate        DateTime?
  estimatedArrival DateTime?
  actualArrival   DateTime?
  destinationId   String?
  destination     Outlet?  @relation(fields: [destinationId], references: [id])
  status          String   @default("preparing") // preparing | in_transit | customs | arrived | delivered
  notes           String?

  createdById     String?
  createdBy       User?    @relation(fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           ShipmentItem[]
  deliveries      Delivery[]
  events          ShipmentEvent[]
}

model ShipmentItem {
  id          String  @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id])
  totalPairs  Int     @default(0)
  notes       String?
}

model ShipmentEvent {
  id          String  @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  eventType   String
  eventDate   DateTime
  location    String?
  notes       String?
  createdAt   DateTime @default(now())
}

// ─── DELIVERIES & QC ──────────────────────────────────────────────────────────

model Delivery {
  id          String  @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id])
  outletId    String
  outlet      Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  receivedAt  DateTime?
  status      String  @default("pending") // pending | partial | complete | disputed
  notes       String?

  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        DeliveryItem[]
  reports      DiscrepancyReport[]
}

model DeliveryItem {
  id                  String  @id @default(cuid())
  deliveryId          String
  delivery            Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  poItemId            String
  poItem              PurchaseOrderItem @relation(fields: [poItemId], references: [id])

  supplierSku         String?
  h2uSku              String?
  colorName           String?

  expectedQty         Int     @default(0)
  receivedQty         Int     @default(0)
  // discrepancyQty is computed: expectedQty - receivedQty

  discrepancyType     String? // shortage | overage | damaged | wrong_item
  damageDescription   String?
  photoUrls           String? // JSON array
  isFlagged           Boolean @default(false)
}

model DiscrepancyReport {
  id                  String  @id @default(cuid())
  reportNumber        String  @unique  // DR-2026-001
  deliveryId          String
  delivery            Delivery @relation(fields: [deliveryId], references: [id])
  totalDiscrepancies  Int     @default(0)
  estimatedLossRm     Float?
  status              String  @default("draft") // draft | sent | acknowledged | resolved
  pdfUrl              String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─── TRENDS ──────────────────────────────────────────────────────────────────

model TrendItem {
  id            String  @id @default(cuid())
  category      String  // color | material | accessory | silhouette | style
  title         String
  description   String?
  imageUrl      String?
  sourceUrl     String?
  sourceName    String?
  market        String?  // MY | TH | GLOBAL
  brand         String?  // e.g. Zara, H&M, Charles & Keith
  colorName     String?  // primary color
  priceMin      Float?   // MYR
  priceMax      Float?   // MYR
  rankPosition  Int?
  salesData     String?
  trendScore    Float?
  season        String?
  scrapedAt     DateTime @default(now())
  validUntil    DateTime?
  isManual      Boolean  @default(false)
}

// ─── COMPETITOR MONITOR ───────────────────────────────────────────────────────

model Competitor {
  id            String   @id @default(cuid())
  name          String
  url           String
  platform      String   @default("shopify")  // shopify | woocommerce | custom
  country       String   @default("MY")
  isActive      Boolean  @default(true)
  lastCrawledAt DateTime?
  createdAt     DateTime @default(now())
  products      CompetitorProduct[]
}

model CompetitorProduct {
  id            String   @id @default(cuid())
  competitorId  String
  competitor    Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  externalId    String
  name          String
  handle        String?
  productUrl    String?
  imageUrl      String?
  priceMin      Float?
  priceMax      Float?
  colors        String?   // JSON: ["Black","Nude","Pink"]
  productType   String?
  isAvailable   Boolean  @default(true)
  isNew         Boolean  @default(true)
  wasRestocked  Boolean  @default(false)
  restockedAt   DateTime?
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([competitorId, externalId])
}

// ─── BEST SELLERS ─────────────────────────────────────────────────────────────

model BestSeller {
  id            String  @id @default(cuid())
  productName   String
  supplierSku   String?
  h2uSku        String?
  category      String  // heels | flats | sandals | boots | bags | accessories | shoe_care | keychain | merchandiser
  season        String?
  colorName     String?
  material      String?
  unitsSold      Int?
  revenueRm      Float?
  marginPct      Float?   // actual gross margin % (e.g. 52 = 52%)
  sellThroughPct Float?   // % of ordered stock sold (e.g. 96 = 96%)
  daysOnSale     Int?     // days the product was on sale (for velocity calc)
  notes          String?
  createdAt      DateTime @default(now())
}

// ─── PRODUCT LIBRARY ──────────────────────────────────────────────────────────

model ProductLibrary {
  id              String   @id @default(cuid())
  libNumber       String   @unique  // PL-2026-001
  productName     String
  h2uSku          String?  // color-level SKU = mainSku + colorCode  e.g. S1800H
  mainSku         String?  // style-level SKU shared across colours  e.g. S1800
  supplierSku     String?
  brand           String?
  category        String?  // heels | flats | sandals | boots | sneakers | wedges | bags | accessories | shoe_care | clearance | keychain | merchandiser
  colorName       String?
  colorCode       String?  // single letter/code appended after mainSku  e.g. H
  season          String?

  // Inventory & status (synced from Shopify export)
  status          String?  // draft | active | low_stock | out_of_stock | clearance | archived
  inventoryTotal  Int?     // total qty across all sizes & locations
  warehouseQty    Int?     // H2U Warehouse (Melaka) qty
  sizeRange       String?  // e.g. "36–41"
  availableSizes  String?  // JSON array of sizes e.g. '["36","37","38","39"]'
  sizeInventory   String?  // JSON object of per-size qty e.g. '{"36":5,"37":4,"38":0}'
  compareAtPrice  Float?   // original price before discount
  productType     String?  // raw Shopify type

  // Material specs
  materialUpper   String?
  materialLining  String?
  materialMidsole String?
  materialOutsole String?
  hardware        String?
  logoSpec        String?
  heelSpec        String?
  platformSpec    String?

  // Material spec photos
  materialUpperPhoto   String?
  materialLiningPhoto  String?
  materialMidsolePhoto String?
  materialOutsolePhoto String?
  hardwarePhoto        String?
  logoSpecPhoto        String?
  heelSpecPhoto        String?
  platformSpecPhoto    String?

  // Cost & pricing (cost from sample received, selling price from PO)
  costRmb         Float?
  costRm          Float?
  sellingPrice    Float?

  // Per-outlet inventory (from Shopify export — summed across all sizes)
  outletInventory String?  // JSON: { "AEON ABM (DEPT)": 5, "H2U Warehouse (Melaka)": 20, ... }

  // Sales velocity (derived from inventory snapshot comparison)
  unitsSold       Int?     // units sold in the tracked window (null = unknown due to restock)
  daysTracked     Int?     // length of the window in days
  aprInventory    Int?     // inventory at start of window (April 6 snapshot)
  restockQty      Int?     // net inventory gain when May > April (velocity indeterminate)

  // Photos
  shoePhotoUrl    String?   // primary shoe photo (main view)
  photoSideUrl    String?   // side view photo
  photoUpperUrl   String?   // upper / top-down view photo
  photoDesignUrl  String?   // design detail / embellishment view
  boxPhotoUrl     String?   // shoe box / packaging photo
  imageUrls       String?   // legacy JSON array

  description     String?   // product description synced from Shopify
  notes           String?

  // Source tracking
  sampleOrderId   String?
  sampleOrder     SampleOrder?  @relation(fields: [sampleOrderId], references: [id])
  manufacturerId  String?
  manufacturer    Manufacturer? @relation(fields: [manufacturerId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  locationInventories LocationInventory[]
}

// ─── LOCATION INVENTORY ───────────────────────────────────────────────────────

model LocationInventory {
  id                String         @id @default(cuid())
  productLibraryId  String
  productLibrary    ProductLibrary @relation(fields: [productLibraryId], references: [id], onDelete: Cascade)
  outletId          String
  outlet            Outlet         @relation(fields: [outletId], references: [id], onDelete: Cascade)

  qty35             Int            @default(0)
  qty36             Int            @default(0)
  qty37             Int            @default(0)
  qty38             Int            @default(0)
  qty39             Int            @default(0)
  qty40             Int            @default(0)
  qty41             Int            @default(0)
  qty42             Int            @default(0)
  totalQty          Int            @default(0)

  notes             String?
  uploadedAt        DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([productLibraryId, outletId])
}

// ─── PER-OUTLET DELIVERY TRACKING ────────────────────────────────────────────

model OutletDelivery {
  id               String   @id @default(cuid())
  poId             String
  po               PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  outletId         String
  outlet           Outlet   @relation(fields: [outletId], references: [id])

  estimatedArrival DateTime?
  actualArrival    DateTime?
  // pending | in_transit | arrived | receipt_done
  status           String   @default("pending")
  notes            String?

  receiptItems     OutletReceiptItem[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([poId, outletId])
}

model OutletReceiptItem {
  id           String         @id @default(cuid())
  deliveryId   String
  delivery     OutletDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  poItemId     String         // links to PurchaseOrderItem
  colorName    String?
  orderedQty   Int            @default(0)
  receivedQty  Int?
  defectQty    Int?
  notes        String?
  receiptDate  DateTime?
}

// ─── VENDOR ASSETS ───────────────────────────────────────────────────────────
model VendorAsset {
  id        String   @id @default(cuid())
  vendor    String
  assetType String   // "box" | "logo"
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendor, assetType])
}
