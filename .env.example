# Copy this file to .env and fill in your values

# Database - SQLite (local) or PostgreSQL (cloud/multi-location)
# For local single-computer use:
DATABASE_URL="file:./dev.db"
# For cloud (Supabase/Neon) - replace with your connection string:
# DATABASE_URL="postgresql://user:password@host:5432/happy2u"

# NextAuth - generate a random secret: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="replace-with-random-secret-string-here"
NEXTAUTH_URL="http://localhost:3000"

# App settings
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_COMPANY_NAME="Happy2U"
